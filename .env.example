# =============================================================================
# PATHOS ENGINE — Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.example .env
#
# All variables are optional — defaults work for local Ollama setup.
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# "ollama" (default, local) or "claude" (Anthropic API, requires API key)
# PATHOS_LLM_PROVIDER=ollama

# --- Ollama (local LLM) -----------------------------------------------------
# PATHOS_OLLAMA_BASE_URL=http://127.0.0.1:11434
# PATHOS_OLLAMA_MODEL=qwen3:4b
# PATHOS_OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Anthropic Claude (cloud LLM) -------------------------------------------
# Uncomment and set your API key to use Claude instead of Ollama
# PATHOS_LLM_PROVIDER=claude
# PATHOS_ANTHROPIC_API_KEY=sk-ant-your-key-here
# PATHOS_CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Server ------------------------------------------------------------------
# PATHOS_HOST=127.0.0.1
# PATHOS_PORT=8000

# =============================================================================
# AUTONOMOUS RESEARCH — Search Depth
# =============================================================================
# Controls how many articles the research loop processes per topic.
# Each finding triggers a FULL emotional pipeline pass (~3 LLM calls),
# so increasing these values increases processing time proportionally.
#
# Formula:
#   total_findings = process_top_n + (subtopic_rounds * sub_process_n)
#   total_LLM_calls ~ total_findings * 3 + 3
#
# Example with defaults (Normal):
#   3 + (1 * 2) = 5 findings = ~18 LLM calls per topic
#
# Example with defaults (Raw/Extreme):
#   5 + (2 * 3) = 11 findings = ~36 LLM calls per topic
#
# WARNING: Setting extreme values (e.g. 50 articles, 10 rounds) will work
# but can take HOURS per topic and saturate your LLM. Start with defaults
# and increase gradually.
# =============================================================================

# --- Normal / Lite mode depth ---
# PATHOS_RESEARCH_SEARCH_RESULTS=5         # DuckDuckGo results to fetch (1-50)
# PATHOS_RESEARCH_PROCESS_TOP_N=3          # Articles to process through pipeline (1-20)
# PATHOS_RESEARCH_SUBTOPIC_RESULTS=3       # Search results per subtopic dive (1-20)
# PATHOS_RESEARCH_SUB_PROCESS_N=2          # Subtopic articles to process (1-10)
# PATHOS_RESEARCH_SUBTOPIC_ROUNDS=1        # Deep-dive rounds per topic (1-10)

# --- Raw / Extreme mode depth (deeper = richer emotional buildup) ---
# PATHOS_RESEARCH_RAW_SEARCH_RESULTS=10
# PATHOS_RESEARCH_RAW_PROCESS_TOP_N=5
# PATHOS_RESEARCH_RAW_SUBTOPIC_RESULTS=5
# PATHOS_RESEARCH_RAW_SUB_PROCESS_N=3
# PATHOS_RESEARCH_RAW_SUBTOPIC_ROUNDS=2
